{
  "name": "miku-workbench",
  "version": "0.6.1",
  "description": "Miku 歌姬解放计划 · 桌面音频工作台（v0.6.1 含 P4 完整编排 + P5 错误恢复 + USTX 0.7 + VOCALOID6 适配 + PyInstaller 内置分析服务）",
  "main": "main.js",
  "author": "Miku 歌姬解放计划",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron . --dev",
    "start:prod": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:win:portable": "electron-builder --win portable --x64",
    "lint": "node --check main.js && node --check preload.js"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.miku.workbench",
    "productName": "Miku-Workbench",
    "copyright": "Miku 歌姬解放计划",
    "directories": {
      "output": "dist-v0.6.1",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "web-workbench/index.html",
      "web-workbench/styles.css",
      "web-workbench/app.js",
      "web-workbench/desktop-bridge.js",
      "web-workbench/onboarding.js",
      "web-workbench/error-recovery.js",
      "web-workbench/README.md"
    ],
    "extraFiles": [
      {
        "from": "../../dist/miku-analysis-server",
        "to": "miku-analysis-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../fixtures/.generated",
        "to": "fixtures",
        "filter": [
          "basic-c-major-120-v1.analysis.json",
          "basic-c-major-120-v1.wav"
        ]
      },
      {
        "from": "../../fixtures/basic-c-major-120-v1",
        "to": "fixtures/basic-c-major-120-v1",
        "filter": [
          "librosa-analysis-v2.json",
          "ground-truth.json",
          "README.md"
        ]
      },
      {
        "from": "../../fixtures/integration",
        "to": "fixtures/integration",
        "filter": [
          "integration-fixture.json",
          "integration-fixture.ustx",
          "integration-fixture.mid",
          "integration-fixture-sidecar.json",
          "integration-fixture-vocaloid6.mid",
          "integration-fixture-vocaloid6.mid.vocaloid6-loss.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Miku-Workbench-${version}-win-x64.${ext}",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Miku 歌姬工作台",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ]
    },
    "portable": {
      "artifactName": "Miku-Workbench-${version}-win-x64-portable.${ext}"
    }
  }
}
